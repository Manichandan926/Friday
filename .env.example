# FRIDAY Configuration
# Copy this file to .env and fill in your values

# LLM Provider (groq, openai, gemini)
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama-3.1-8b-instant

# API Keys (get from respective provider dashboards)
GROQ_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Database
DATABASE_URL=sqlite:///database/friday.db

# Logging
LOG_LEVEL=INFO
